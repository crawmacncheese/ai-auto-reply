flowchart LR
  %% Nodes
  A([Start])
  B[Classifier]
  R{"Reply<br/>Needed?"}
  C{"User<br/>Actions<br/>Required?"}
  D[Actions<br/>Summarizer]
  E[User<br/>Actions<br/>Taken]
  F[Inferencer]
  G[Topics<br/>Suggester]
  H[Message<br/>Generator]
  Z([End])

  %% Edges (with labels)
  A -- "Existing convo history;<br/>Job seeker's profile (opt.);<br/>Referrer's profile (opt.);<br/>Job description (opt.)" --> B
  B -- "Conversation<br/>categories" --> R
  R -- "No" --> Z
  R -- "Yes" --> C
  C -- "Yes" --> D
  C -- "No" --> G
  D -- "Questions/Required actions from referrer" --> E
  E -- "Answers/Actions<br/>from job seeker" --> F
  F -- "Inferenced results (e.g., referral is impossible with fulfilled actions)" --> G
  G -- "Suggested<br/>topics" --> H
  H -- "Suggested<br/>message" --> Z

